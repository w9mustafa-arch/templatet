---
interface Props {
  title: string;
  highlightText?: string;
  description: string;
}

const { title, highlightText, description } = Astro.props;

let titleStart = title;
let titleEnd = "";

if (highlightText) {
  const titleParts = title.split(highlightText);
  if (titleParts.length > 1) {
    titleStart = titleParts[0];
    titleEnd = titleParts[1];
  }
}
---

<!-- Hero Section -->
<section class="relative overflow-hidden bg-gradient-to-br from-[#0f172a] via-[#1e293b] to-[#d73d3f] pt-24 md:pt-32 pb-16 md:pb-20">
  
  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/40"></div>

  <!-- Content -->
  <div class="container-custom relative z-10">
    <div class="text-center max-w-3xl mx-auto px-4">
      
      <h1 class="text-3xl md:text-4xl lg:text-5xl mb-4 md:mb-6 text-white animate-slide-down">
        {highlightText ? (
          <>
            {titleStart}
            <span class="text-[#ff6b6b]">{highlightText}</span>
            {titleEnd}
          </>
        ) : (
          title
        )}
      </h1>

      <p class="text-lg md:text-xl text-gray-200 mb-6 md:mb-8 animate-slide-up" style="animation-delay: 200ms">
        {description}
      </p>

    </div>
  </div>
  
  <!-- Glow -->
  <div class="absolute -bottom-20 left-0 right-0 flex justify-center">
    <div class="w-64 h-64 bg-[#d73d3f] rounded-full blur-3xl opacity-40"></div>
  </div>

</section>
