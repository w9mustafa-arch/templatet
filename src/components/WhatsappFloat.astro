---
const phone = "212600000000";
const message = "Bonjour, je veux une livraison 🚚";
const url = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<a 
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  id="whatsapp-float"
  class="fixed bottom-6 right-6 z-[9999] flex items-center justify-center w-14 h-14 rounded-full bg-green-500 hover:bg-green-600 text-white shadow-lg transition-all duration-500 opacity-0 translate-y-10 pointer-events-none"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="w-7 h-7 fill-white">
  <path d="M16 .396C7.163.396 0 7.558 0 16.396c0 2.89.757 5.602 2.078 7.955L.086 32l7.87-1.977a15.94 15.94 0 008.044 2.197h.006c8.837 0 16-7.162 16-16S24.843.396 16 .396zm0 29.207c-2.55 0-5.04-.676-7.204-1.957l-.516-.305-4.67 1.173 1.245-4.553-.335-.532a13.4 13.4 0 01-2.06-7.212c0-7.41 6.03-13.44 13.44-13.44 3.59 0 6.96 1.4 9.5 3.94a13.36 13.36 0 013.94 9.5c0 7.41-6.03 13.44-13.44 13.44zm7.37-10.05c-.4-.2-2.36-1.16-2.73-1.3-.37-.14-.64-.2-.91.2-.27.4-1.04 1.3-1.27 1.57-.23.27-.46.3-.86.1-.4-.2-1.7-.63-3.24-2-.94-.84-1.58-1.87-1.76-2.2-.18-.34-.02-.52.14-.69.14-.14.3-.36.45-.54.15-.18.2-.3.3-.5.1-.2.05-.38-.02-.54-.07-.16-.91-2.2-1.25-3.02-.33-.8-.67-.7-.91-.71h-.78c-.27 0-.7.1-1.06.5-.36.4-1.4 1.36-1.4 3.32s1.43 3.86 1.63 4.12c.2.27 2.8 4.27 6.78 5.98.95.41 1.7.65 2.28.83.96.3 1.84.26 2.54.16.77-.11 2.36-.96 2.7-1.88.34-.92.34-1.71.24-1.88-.1-.17-.37-.27-.77-.47z"/>
</svg>
</a>

<script>
  function initWhatsAppButton() {
    const button = document.getElementById('whatsapp-float');
    const hero = document.getElementById('hero');

    if (!button) return;

    // نحطو الزر في body دائماً
    document.body.appendChild(button);

    if (!hero) {
      // إذا ما كاينش hero (مثلاً صفحة contact)
      button.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
      button.classList.add('opacity-100', 'translate-y-0');
      return;
    }

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) {
          button.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
          button.classList.add('opacity-100', 'translate-y-0');
        } else {
          button.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
          button.classList.remove('opacity-100', 'translate-y-0');
        }
      },
      { threshold: 0.2 }
    );

    observer.observe(hero);
  }

  // ✅ أول تحميل
  initWhatsAppButton();

  // ✅ كل مرة تبدل الصفحة (مهم جداً)
  document.addEventListener('astro:page-load', () => {
    initWhatsAppButton();
  });
</script>
