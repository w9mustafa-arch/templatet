---
const phone = "212600000000";
const message = "Bonjour, je veux une livraison 🚚";
const url = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<a 
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  id="whatsapp-float"
  class="group fixed bottom-6 right-6 z-[9999] flex items-center justify-center w-16 h-16 rounded-full 
  bg-gradient-to-tr from-green-500 to-green-600 
  text-white shadow-xl 
  hover:scale-110 hover:shadow-2xl 
  transition-all duration-300 
  opacity-0 translate-y-10 pointer-events-none animate-pulse"
>
  <!-- Tooltip -->
  <span class="absolute right-20 bg-black text-white text-sm px-3 py-1 rounded-md opacity-0 group-hover:opacity-100 transition whitespace-nowrap">
    Contactez-nous
  </span>

  <!-- Icon -->
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="w-8 h-8 fill-white">
    <path d="M16 .396C7.163.396 0 7.558 0 16.396c0 2.89.757 5.602 2.078 7.955L.086 32l7.87-1.977a15.94 15.94 0 008.044 2.197h.006c8.837 0 16-7.162 16-16S24.843.396 16 .396zm0 29.207c-2.55 0-5.04-.676-7.204-1.957l-.516-.305-4.67 1.173 1.245-4.553-.335-.532a13.4 13.4 0 01-2.06-7.212c0-7.41 6.03-13.44 13.44-13.44 3.59 0 6.96 1.4 9.5 3.94a13.36 13.36 0 013.94 9.5c0 7.41-6.03 13.44-13.44 13.44z"/>
  </svg>
</a>

<script>
  function initWhatsAppButton() {
    const button = document.getElementById('whatsapp-float');
    const hero = document.getElementById('hero');

    if (!button) return;

    // نحطو الزر في body دائماً
    document.body.appendChild(button);

    if (!hero) {
      // إذا ما كاينش hero (مثلاً صفحة contact)
      button.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
      button.classList.add('opacity-100', 'translate-y-0');
      return;
    }

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) {
          button.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
          button.classList.add('opacity-100', 'translate-y-0');
        } else {
          button.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
          button.classList.remove('opacity-100', 'translate-y-0');
        }
      },
      { threshold: 0.2 }
    );

    observer.observe(hero);
  }

  // ✅ أول تحميل
  initWhatsAppButton();

  // ✅ كل مرة تبدل الصفحة (مهم جداً)
  document.addEventListener('astro:page-load', () => {
    initWhatsAppButton();
  });
</script>
