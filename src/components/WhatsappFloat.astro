---
const phone = "212600000000";
const message = "Bonjour, je veux une livraison 🚚";
const url = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<div id="wa-container" class="fixed bottom-5 right-5 z-[9999] flex flex-col items-end gap-3 pointer-events-none">

  <!-- Message -->
  <div id="wa-msg" class="bg-white text-gray-800 text-sm px-4 py-2 rounded-xl shadow-md opacity-0 translate-y-2 transition-all duration-300">
    💬 Bonjour 👋<br/>
    Nous sommes disponibles !
  </div>

  <!-- Button -->
  <a 
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  id="wa-btn"
  class="flex items-center gap-2.5 bg-[#25D366] hover:bg-[#1ebe5d] text-white px-4 py-2.5 rounded-full shadow-lg transition-all duration-300 scale-0 opacity-0"
>
  <!-- Icon -->
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="w-5 h-5 shrink-0 fill-white">
    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
  </svg>

  <!-- Text -->
  <span class="text-sm font-medium leading-none">
    Chat WhatsApp
  </span>
</a>

</div>

<script>
  function initWhatsAppReal() {
    const btn = document.getElementById('wa-btn');
    const msg = document.getElementById('wa-msg');
    const container = document.getElementById('wa-container');
    const hero = document.getElementById('hero');

    if (!btn || !container) return;

    document.body.appendChild(container);

    function show() {
      container.classList.remove('pointer-events-none');
      btn.classList.remove('scale-0', 'opacity-0');
      btn.classList.add('scale-100', 'opacity-100');

      // message bubble
      setTimeout(() => {
        msg.classList.remove('opacity-0', 'translate-y-2');
      }, 400);

      setTimeout(() => {
        msg.classList.add('opacity-0', 'translate-y-2');
      }, 4000);
    }

    function hide() {
      container.classList.add('pointer-events-none');
      btn.classList.add('scale-0', 'opacity-0');
      btn.classList.remove('scale-100', 'opacity-100');
      msg.classList.add('opacity-0', 'translate-y-2');
    }

    if (!hero) {
      show();
      return;
    }

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          // داخل hero → خبي
          hide();
        } else {
          // خرج من hero → بين
          show();
        }
      },
      { threshold: 0.3 }
    );

    observer.observe(hero);
  }

  initWhatsAppReal();

  document.addEventListener('astro:page-load', () => {
    initWhatsAppReal();
  });
</script>
