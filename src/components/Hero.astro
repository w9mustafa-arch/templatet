---
<section class="relative pt-10 pb-20 md:pt-12 overflow-hidden hero-section">
  <div class="container-custom relative z-10">
    <div class="grid md:grid-cols-2 gap-12 items-center">

      <!-- الصورة -->
      <div class="relative fade-in" transition:animate="fade">
        <div class="w-full max-w-lg mx-auto">
          <img 
  src="/cover.svg" 
  alt="Service de livraison à Marrakech"
  loading="eager"
  fetchpriority="high"
  width="600"
  height="500"
  class="w-full h-auto drop-shadow-xl"
/>
        </div>
      </div>

      <!-- النص -->
      <div class="slide-up" transition:animate="slide">
        <h1 class="mb-6 text-3xl md:text-4xl text-secondary-900 dark:text-white leading-tight">
          Votre livreur rapide à Marrakech
          <span class="text-primary-600 dark:text-primary-400"> 24h/7j</span>
        </h1>

        <p class="text-xl text-secondary-600 dark:text-secondary-300 mb-8 max-w-lg">
          Livraison rapide de repas, courses et médicaments directement chez vous, partout à Marrakech. 77
        </p>

        <!-- الأزرار -->
        <div class="flex flex-wrap gap-4">
          <a href="https://github.com/larry-xue/astro-sassify-template" target="_blank" class="btn-primary flex items-center">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
             Appeler
          </a>

