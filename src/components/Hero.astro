---
---
<section class="relative pt-16 pb-20 md:pt-20 overflow-hidden hero-section">
  <div class="container-custom relative z-10">
    <div class="grid md:grid-cols-2 gap-12 items-center">

      <!-- الصورة -->
      <div class="relative fade-in" transition:animate="fade">
        <div class="w-full max-w-lg mx-auto">
          <img 
            src="/livraison-marrakech.svg" 
            alt="Service de livraison à Marrakech" 
            class="w-full h-auto drop-shadow-xl"
          />
        </div>
      </div>

      <!-- النص -->
      <div class="slide-up" transition:animate="slide">
        <h1 class="mb-6 text-secondary-900 dark:text-white leading-tight">
          Votre Livreur à Marrakech 
          <span class="text-primary-600 dark:text-primary-400">24h/7j</span>
        </h1>

        <p class="text-xl text-secondary-600 dark:text-secondary-300 mb-8 max-w-lg">
          pour livrer rapidement vos repas, courses et médicaments directement chez vous.
          Un service simple, rapide et fiable partout dans la ville.
        </p>

        <!-- الأزرار -->
        <div class="flex flex-wrap gap-4">
          <a href="#" class="btn-primary flex items-center">
            Appeler
          </a>

          <a href="#" class="btn-outline flex items-center">
            WhatsApp
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
