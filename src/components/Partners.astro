<style>
/* بدون مسافات */
.partners {
  overflow: hidden;
}

/* container */
.slider {
  overflow: hidden;
}

/* track */
.track {
  display: flex;
  gap: 12px;
  width: max-content;
  animation: scroll 25s linear infinite;
}

/* cards */
.card {
  flex-shrink: 0;
  border-radius: 14px;
  overflow: hidden;
}

.card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* sizes */
.square {
  width: 90px;
  height: 90px;
}

.wide {
  width: 200px;
  height: 90px;
}

/* animation */
@keyframes scroll {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}
</style>
