---
const features = [
{
title:"Livraison de repas",
description:"Recevez rapidement chez vous les plats de vos restaurants préférés : McDonald's, KFC, Pizza Hut et de nombreux restaurants locaux à Marrakech.",
image:"/repas.jpg",
alt:"Livraison de repas à domicile à Marrakech"
},
{
title:"Livraison de courses",
description:"Nous récupérons vos courses et les livrons directement chez vous à Marrakech, rapidement et en toute simplicité.",
image:"/courses.jpg",
alt:"Service de livraison de courses à Marrakech"
},
{
title:"Livraison de pharmacie",
description:"Nous livrons vos médicaments et produits pharmaceutiques directement à votre domicile à Marrakech, rapidement et en toute discrétion.",
image:"/pharmacie.jpg",
alt:"Livraison de médicaments pharmacie Marrakech"
}
];
---

<section id="features" class="section bg-gray-50 dark:bg-gray-800/50">

<div class="container-custom">

<div class="text-center max-w-3xl mx-auto mb-16">

<span class="inline-block px-4 py-1 rounded-full bg-secondary-100 dark:bg-secondary-900 text-secondary-600 dark:text-secondary-300 font-medium text-sm mb-4">
        Services
      </span>

<h3 class="mb-6 text-gray-900 dark:text-white">Nos Services de Livraison</h3>
      <p class="text-gray-600 dark:text-gray-300">
        Découvrez nos services de livraison rapides et fiables disponibles partout à Marrakech.
      </p>

</div>


<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

{features.map((feature) => (

<div class="feature-card">

<div class="card p-6 md:p-8 h-full">

<h3 class="text-xl font-semibold mb-3 text-gray-900 dark:text-white">
{feature.title}
</h3>

<p class="text-gray-600 dark:text-gray-300 mb-6">
{feature.description}
</p>

<div class="relative h-32 rounded-lg overflow-hidden">

<img
  src={feature.image}
  alt={feature.alt}
  class="w-full h-full object-cover"
/>
</div>

</div>

</div>

))}

</div>


<div class="mt-16 text-center">

<a href="/features" class="btn">
Explore All Features
</a>

</div>

</div>

</section>
