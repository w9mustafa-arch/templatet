---
const features = [
  {
    title: "Livraison Rapide",
    description: "Recevez vos repas, courses et médicaments directement chez vous en un temps record, 24h/7j.",
    icon: "M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2M7 2v4M11 2v4M15 2v11a3 3 0 003 3h1a2 2 0 002-2v-3M19 16v5",
    color: "secondary",
  },
  {
    title: "Produits Pharmaceutiques",
    description: "Livraison discrète et rapide de médicaments et produits essentiels directement à votre porte.",
    icon: "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z",
    color: "secondary"
  },
  {
    title: "Repas de Restaurants",
    description: "Commandez vos plats préférés de McDonald's, KFC, Pizza Hut et restaurants locaux avec livraison rapide.",
    icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
    color: "primary"
  },
  {
