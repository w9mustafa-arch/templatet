---
const features = [
{
title:"Livraison de repas",
description:"Recevez vos repas rapidement à Marrakech.",
image:"/repas.jpg",
alt:"Livraison de repas à domicile à Marrakech"
},
{
title:"Livraison de courses",
description:"Nous livrons vos courses directement chez vous.",
image:"/courses.jpg",
alt:"Service de livraison de courses à Marrakech"
},
{
title:"Livraison de pharmacie",
description:"Livraison rapide de médicaments à domicile.",
image:"/pharmacie.jpg",
alt:"Livraison de médicaments pharmacie Marrakech"
}
];
---

<section id="features" class="section bg-gray-50 dark:bg-gray-800/50">

<div class="container-custom">

<div class="text-center max-w-3xl mx-auto mb-16">

<span class="inline-block px-4 py-1 rounded-full bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-300 font-medium text-sm mb-4">
Powerful Features
</span>

<h2 class="mb-6 text-gray-900 dark:text-white">
Everything You Need to Succeed
</h2>

<p class="text-gray-600 dark:text-gray-300">
Our platform provides all the tools you need to grow your business.
</p>

</div>


<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

{features.map((feature) => (

<div class="feature-card">

<div class="card p-6 md:p-8 h-full">

<h3 class="text-xl font-semibold mb-3 text-gray-900 dark:text-white">
{feature.title}
</h3>

<p class="text-gray-600 dark:text-gray-300 mb-6">
{feature.description}
</p>

<div class="relative h-32 rounded-lg overflow-hidden">

<img
  src={feature.image}
  alt={feature.alt}
  class="w-full h-full object-cover"
/>
</div>

</div>

</div>

))}

</div>


<div class="mt-16 text-center">

<a href="/features" class="btn-primary">
Explore All Features
</a>

</div>

</div>

</section>
