---
const features = [
{
title:"Food Delivery",
description:"Order from top restaurants like McDonald's, KFC, Pizza Hut, and popular local spots — delivered fast and fresh.",
image:"/food-delivery-marrakech.svg",
alt:"Food delivery from restaurants like McDonald's, KFC, and Pizza Hut in Marrakech"
},
{
title:"Grocery Delivery",
description:"We pick up your groceries and deliver them straight to your home — quick, simple, and reliable.",
image:"/grocery-delivery-marrakech.svg",
alt:"Grocery delivery service bringing fresh products to your home in Marrakech"
},
{
title:"Pharmacy Delivery",
description:"Get your medications and pharmacy essentials delivered to your door — safely, quickly, and discreetly.",
image:"/pharmacy-delivery-marrakech.svg",
alt:"Pharmacy delivery service for medicines and healthcare products in Marrakech"
}
];
---

<section id="features" class="section bg-gray-50 dark:bg-gray-800/50">

<div class="container-custom">

<div class="text-center max-w-3xl mx-auto mb-16">

<span class="inline-block px-4 py-1 rounded-full bg-secondary-100 dark:bg-secondary-900 text-secondary-600 dark:text-secondary-300 font-medium text-sm mb-4">
        Services
      </span>

<h2 class="mb-6 text-gray-900 dark:text-white">Our Delivery Services</h2>
      <p class="text-gray-600 dark:text-gray-300">
        Everything you need, delivered fast in Marrakech.
      </p>

</div>


<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

{features.map((feature) => (

<div class="feature-card">

<div class="card p-6 md:p-8 h-full">

<h3 class="text-xl font-semibold mb-3 text-gray-900 dark:text-white">
{feature.title}
</h3>

<p class="text-gray-600 dark:text-gray-300 mb-6">
{feature.description}
</p>

<div class="relative h-32 rounded-lg overflow-hidden">

<img
  src={feature.image}
  alt={feature.alt}
  class="w-full h-full object-cover"
/>
</div>

</div>

</div>

))}

</div>

</div>

</section>
