---
const features = [
  {
    title: "Livraison Rapide",
    description: "Recevez vos repas, courses et médicaments directement chez vous en un temps record, 24h/7j.",
    icon: "M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2M7 2v4M11 2v4M15 2v11a3 3 0 003 3h1a2 2 0 002-2v-3M19 16v5",
    color: "secondary",
  },
  {
    title: "Produits Pharmaceutiques",
    description: "Livraison discrète et rapide de médicaments et produits essentiels directement à votre porte.",
    icon: "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z",
    color: "secondary"
  },
  {
    title: "Repas de Restaurants",
    description: "Commandez vos plats préférés de McDonald's, KFC, Pizza Hut et restaurants locaux avec livraison rapide.",
    icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
    color: "primary"
  },
  {
    title: "Livraison de Cadeaux",
    description: "Fleurs, cadeaux et attentions spéciales livrés avec soin à vos proches ou clients.",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
    color: "secondary"
  },
  {
    title: "Couverture Totale",
    description: "Nous livrons dans tous les quartiers de Marrakech et zones avoisinantes.",
    icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15",
    color: "primary"
  },
  {
    title: "Service 24h/7j",
    description: "Notre équipe est disponible à toute heure pour répondre à vos besoins de livraison à domicile.",
    icon: "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z",
    color: "secondary"
  }
];
---

<section id="features" class="section bg-gray-50 dark:bg-gray-800/50 py-16">
  <div class="container-custom">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-4 py-1 rounded-full bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-300 font-medium text-sm mb-4">
        Nos Services
      </span>
      <h2 class="text-3xl font-bold mb-6 text-gray-900 dark:text-white">Tout ce dont vous avez besoin</h2>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="feature-card-wrapper group">
          <div class="particles-container relative card p-8 h-full bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 overflow-hidden transition-all duration-300 hover:shadow-2xl">
            <div class="particles absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            
            <div class="relative z-10">
              <div class={`w-14 h-14 rounded-xl bg-${feature.color}-100 dark:bg-${feature.color}-900/30 flex items-center justify-center mb-6 transition-transform duration-500 group-hover:scale-110`}>
                <svg class={`w-7 h-7 text-${feature.color}-600 dark:text-${feature.color}-400`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={feature.icon}></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">{feature.title}</h3>
              <p class="text-gray-600 dark:text-gray-300 leading-relaxed">{feature.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .particles-container {
    transition: transform 0.3s ease;
  }
  
  .particles-container:hover {
    transform: translateY(-5px);
  }

  /* تأثير الأنيميشن للجزيئات */
  @keyframes float-particle {
    0% {
      transform: translateY(0) translateX(0);
      opacity: 0;
    }
    50% {
      opacity: 0.6;
    }
    100% {
      transform: translateY(-40px) translateX(20px);
      opacity: 0;
    }
  }
</style>

<script>
  function initFeatureParticles() {
    const containers = document.querySelectorAll('.particles-container');
    
    containers.forEach(container => {
      const particlesElement = container.querySelector('.particles');
      if (!particlesElement) return;

      const createParticles = () => {
        particlesElement.innerHTML = '';
        const count = 20; // عدد الجزيئات لكل بطاقة
        
        for (let i = 0; i < count; i++) {
          const particle = document.createElement('div');
          const size = Math.random() * 4 + 2;
          const left = Math.random() * 100;
          const top = Math.random() * 100;
          const duration = Math.random() * 2 + 1.5;
          const delay = Math.random() * 2;
          
          particle.style.cssText = `
            position: absolute;
            width: ${size}px;
            height: ${size}px;
            background-color: #FE9900; /* لون البراند الخاص بك */
            border-radius: 50%;
            left: ${left}%;
            top: ${top}%;
            opacity: 0;
            animation: float-particle ${duration}s ease-in-out ${delay}s infinite;
          `;
          particlesElement.appendChild(particle);
        }
      };

      createParticles();
    });
  }

  // تشغيل عند تحميل الصفحة أو التنقل في Astro
  document.addEventListener('DOMContentLoaded', initFeatureParticles);
  document.addEventListener('astro:page-load', initFeatureParticles);
</script>
