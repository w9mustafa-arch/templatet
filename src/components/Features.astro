---
const features = [
  {
    title: "Intuitive Dashboard",
    description: "Get a comprehensive overview of your business with our easy-to-use dashboard.",
    icon: "M9 17V7m0 10a2 2 0 01-2 2H5",
    color: "primary"
  },
  {
    title: "Advanced Analytics",
    description: "Make data-driven decisions with powerful analytics tools.",
    icon: "M9 19v-6a2 2 0 00-2-2H5",
    color: "secondary"
  },
  {
    title: "Team Collaboration",
    description: "Enhance productivity with real-time collaboration.",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857",
    color: "accent"
  },
  {
    title: "Automated Workflows",
    description: "Save time with automation that streamlines processes.",
    icon: "M4 4v5h.582",
    color: "warning"
  },
  {
    title: "Secure Data Storage",
    description: "Enterprise-grade security for your sensitive data.",
    icon: "M12 15v2",
    color: "primary"
  },
  {
    title: "Mobile Accessibility",
    description: "Access your workspace from any device.",
    icon: "M12 18h.01",
    color: "secondary"
  }
];
---

<section id="features" class="section bg-gray-50 dark:bg-gray-800/50">

<div class="container-custom">

<div class="text-center max-w-3xl mx-auto mb-16">
<span class="inline-block px-4 py-1 rounded-full bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-300 font-medium text-sm mb-4">
Powerful Features
</span>

<h2 class="mb-6 text-gray-900 dark:text-white">
Everything You Need to Succeed
</h2>

<p class="text-gray-600 dark:text-gray-300">
Our platform provides all the tools you need to grow your business.
</p>
</div>


<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

{features.map((feature) => (

<div class="feature-card">

<div class="card p-6 md:p-8 h-full">

<div class={`w-14 h-14 rounded-xl bg-${feature.color}-100 dark:bg-${feature.color}-900/30 flex items-center justify-center mb-6`}>

<svg
class={`w-7 h-7 text-${feature.color}-600 dark:text-${feature.color}-400`}
fill="none"
stroke="currentColor"
viewBox="0 0 24 24"
>

<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={feature.icon}></path>

</svg>

</div>


<h3 class="text-xl font-semibold mb-3 text-gray-900 dark:text-white">
{feature.title}
</h3>

<p class="text-gray-600 dark:text-gray-300 mb-6">
{feature.description}
</p>


<div class="particles-container relative h-32 bg-gray-50 dark:bg-secondary-900 rounded-lg overflow-hidden flex items-center justify-center">

<div class="particles absolute inset-0"></div>

</div>

</div>

</div>

))}

</div>


<div class="mt-16 text-center">

<a href="/features" class="btn-primary">
Explore All Features
</a>

</div>

</div>

</section>


<style>

.particles-container:hover .particles {
opacity:1;
}

.particles {
opacity:0;
transition:opacity .3s ease;
}

.particle {
position:absolute;
width:4px;
height:4px;
background:#6366f1;
border-radius:50%;
animation:float 2s ease-in-out infinite alternate;
}

@keyframes float {

0%{
transform:translateY(0);
opacity:0;
}

50%{
opacity:.8;
}

100%{
transform:translateY(-20px);
opacity:0;
}

}

</style>


<script>

document.addEventListener("DOMContentLoaded",()=>{

document.querySelectorAll(".particles").forEach(container=>{

for(let i=0;i<25;i++){

const p=document.createElement("div")

p.className="particle"

p.style.left=Math.random()*100+"%"

p.style.top=Math.random()*100+"%"

p.style.animationDelay=Math.random()*2+"s"

container.appendChild(p)

}

})

})

</script>
