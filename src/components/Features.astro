---
const features = [
{
title:"Livraison de repas",
description:"Recevez vos repas rapidement à Marrakech directement chez vous.",
image:"/repas.jpg",
alt:"Livraison de repas à domicile à Marrakech"
},
{
title:"Livraison de courses",
description:"Nous livrons vos courses rapidement partout à Marrakech.",
image:"/courses.jpg",
alt:"Service de livraison de courses à Marrakech"
},
{
title:"Livraison de pharmacie",
description:"Livraison rapide de médicaments et produits de pharmacie.",
image:"/pharmacie.jpg",
alt:"Livraison de médicaments pharmacie Marrakech"
}
];
---

<section id="features" class="section bg-gray-50 dark:bg-gray-800/50">

<div class="container-custom">

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

{features.map((feature) => (

<div class="feature-card">

<div class="card p-6 md:p-8 h-full">

<div class="text-center">

<span class="inline-block px-4 py-1 rounded-full bg-secondary-100 dark:bg-secondary-900 text-secondary-600 dark:text-secondary-300 font-medium text-sm mb-4">
Service
</span>

<h3 class="mb-4 text-gray-900 dark:text-white text-xl font-semibold">
{feature.title}
</h3>

<p class="text-gray-600 dark:text-gray-300 mb-6">
{feature.description}
</p>

</div>

<div class="relative h-32 rounded-lg overflow-hidden">

<img
src={feature.image}
alt={feature.alt}
class="w-full h-full object-cover"
/>

</div>

</div>

</div>

))}

</div>

</div>

</section>
