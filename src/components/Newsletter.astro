<section id="delivery-zones" class="py-20 bg-gray-50 dark:bg-gray-900">
  <div class="container-custom mx-auto px-4">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        Delivery Areas in Marrakech 📍
      </h2>
      <p class="text-gray-600 dark:text-gray-300">
        Click on any area to load the map.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 items-start">

      <!-- Zones -->
      <div class="grid grid-cols-2 gap-4">

        <button onclick="loadMap(31.6295, -8.0089)" class="zone-btn">Gueliz</button>
        <button onclick="loadMap(31.6210, -8.0160)" class="zone-btn">Medina</button>
        <button onclick="loadMap(31.6245, -8.0123)" class="zone-btn">Hivernage</button>
        <button onclick="loadMap(31.6600, -7.9500)" class="zone-btn">Palmeraie</button>
        <button onclick="loadMap(31.6000, -8.0500)" class="zone-btn">Targa</button>
        <button onclick="loadMap(31.5900, -8.0700)" class="zone-btn">Massira</button>

      </div>

      <!-- Map (Lazy Load) -->
      <div id="map-container" class="w-full h-[400px] rounded-2xl overflow-hidden shadow-lg bg-gray-200 flex items-center justify-center">
        
        <button onclick="loadMap(31.6295, -8.0089)" class="bg-blue-600 text-white px-6 py-3 rounded-xl shadow-lg">
          Show Map 📍
        </button>

      </div>

    </div>

  </div>
</section>

<script>
  function loadMap(lat, lng) {
    const container = document.getElementById("map-container");

    container.innerHTML = `
      <iframe
        class="w-full h-full border-0"
        src="https://maps.google.com/maps?q=${lat},${lng}&z=14&output=embed">
      </iframe>
    `;
  }
</script>
