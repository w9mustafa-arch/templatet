<section id="delivery-zones" class="py-20 bg-gray-50 dark:bg-gray-900">
  <div class="container-custom mx-auto px-4">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-10">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        Delivery Areas in Marrakech 🚚
      </h2>
      <p class="text-gray-600 dark:text-gray-300">
        Search your area and order instantly.
      </p>
    </div>

    <!-- Search -->
    <div class="max-w-xl mx-auto mb-10">
      <input 
        type="text" 
        id="zoneSearch"
        placeholder="Search your area..."
        class="w-full p-4 rounded-xl border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-800 dark:text-white focus:outline-none"
      />
    </div>

    <!-- Zones -->
    <div id="zonesList" class="flex flex-wrap justify-center gap-3 max-w-5xl mx-auto">

      <!-- مناطق ظاهرة -->
      <button class="zone-chip" onclick="order('Gueliz')">Gueliz</button>
      <button class="zone-chip" onclick="order('Medina')">Medina</button>
      <button class="zone-chip" onclick="order('Hivernage')">Hivernage</button>
      <button class="zone-chip" onclick="order('Palmeraie')">Palmeraie</button>
      <button class="zone-chip" onclick="order('Targa')">Targa</button>

      <!-- مناطق مخفية -->
      <button class="zone-chip hidden-zone" data-hidden="true" onclick="order('Hay Hassani')">Hay Hassani</button>
      <button class="zone-chip hidden-zone" data-hidden="true" onclick="order('Azli')">Azli</button>
      <button class="zone-chip hidden-zone" data-hidden="true" onclick="order('Saada')">Saada</button>
      <button class="zone-chip hidden-zone" data-hidden="true" onclick="order('Izdihar')">Izdihar</button>
      <button class="zone-chip hidden-zone" data-hidden="true" onclick="order('Tamansourt')">Tamansourt</button>

    </div>

  </div>
</section>

<!-- CSS -->
<style>
.zone-chip {
  padding: 10px 16px;
  border-radius: 999px;
  background: white;
  border: 1px solid #e5e7eb;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: 0.3s;
}

.zone-chip:hover {
  background: #2563eb;
  color: white;
  transform: scale(1.05);
}

/* إخفاء المناطق المخفية */
.hidden-zone {
  display: none;
}
</style>

<!-- JavaScript -->
<script>
document.addEventListener("DOMContentLoaded", function () {

  const searchInput = document.getElementById("zoneSearch");
  const zones = document.querySelectorAll(".zone-chip");

  // 🔍 البحث
  searchInput.addEventListener("input", function () {
    const value = this.value.toLowerCase();

    zones.forEach(zone => {
      const text = zone.textContent.toLowerCase();
      const isHidden = zone.getAttribute("data-hidden");

      if (value === "") {
        // إذا البحث فارغ
        zone.style.display = isHidden ? "none" : "inline-block";
      } else {
        // أثناء البحث
        zone.style.display = text.includes(value) ? "inline-block" : "none";
      }
    });
  });

  // 📲 الطلب عبر واتساب
  window.order = function(area) {
    const phone = "212600000000"; // ضع رقمك هنا
    const message = `Bonjour, je veux une livraison à ${area} 🚚`;
    window.open(`https://wa.me/${phone}?text=${encodeURIComponent(message)}`, "_blank");
  };

});
</script>
