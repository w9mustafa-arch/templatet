<!-- 🎨 CSS -->
<style>
.zone-card {
  padding: 12px 20px;
  border-radius: 12px;
  background: white;
  border: 1px solid #e5e7eb;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
  color: #111827;
}

/* 🌙 Dark mode */
.dark .zone-card {
  background: #1f2937; /* نفس bg-gray-800 */
  border-color: #374151; /* نفس gray-700 */
  color: white;
}

/* ✨ Hover */
.zone-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
  background: linear-gradient(to right, #D73D3F, #D73D3F);
  color: white;
  border-color: transparent;
}

/* مخفي */
.hidden-zone {
  display: none;
}
</style>

<!-- ⚡ JavaScript -->
<script>
document.addEventListener("DOMContentLoaded", function () {

  const searchInput = document.getElementById("zoneSearch");
  const zones = document.querySelectorAll(".zone-card");

  // 🔍 Search
  searchInput.addEventListener("input", function () {
    const value = this.value.toLowerCase();

    zones.forEach(zone => {
      const text = zone.textContent.toLowerCase();
      const isHidden = zone.getAttribute("data-hidden");

      if (value === "") {
        zone.style.display = isHidden ? "none" : "inline-block";
      } else {
        zone.style.display = text.includes(value) ? "inline-block" : "none";
      }
    });
  });

  // 📲 WhatsApp
  window.order = function(area) {
    const phone = "212600000000";
    const message = `Hello, I want delivery in ${area} 🚚`;
    window.open(`https://wa.me/${phone}?text=${encodeURIComponent(message)}`, "_blank");
  };

});


window.contactWhatsApp = function() {
  const phone = "212600000000";
  const message = "Hello 👋 I can't find my area. Can you help me with delivery? 🚚";
  window.open(`https://wa.me/${phone}?text=${encodeURIComponent(message)}`, "_blank");
};
</script>
