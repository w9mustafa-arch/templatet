<section id="delivery-zones" class="py-20 bg-gray-50 dark:bg-gray-900">
  <div class="container-custom mx-auto px-4">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        Delivery Areas in Marrakech 📍
      </h2>
      <p class="text-gray-600 dark:text-gray-300">
        Click on any area to see it on the map.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 items-start">

      <!-- Zones -->
      <div class="grid grid-cols-2 gap-4">

        <button onclick="focusMap(31.6295, -8.0089)" class="zone-btn">Gueliz</button>
        <button onclick="focusMap(31.6210, -8.0160)" class="zone-btn">Medina</button>
        <button onclick="focusMap(31.6245, -8.0123)" class="zone-btn">Hivernage</button>
        <button onclick="focusMap(31.6600, -7.9500)" class="zone-btn">Palmeraie</button>
        <button onclick="focusMap(31.6000, -8.0500)" class="zone-btn">Targa</button>
        <button onclick="focusMap(31.5900, -8.0700)" class="zone-btn">Massira</button>

      </div>

      <!-- Map -->
      <div class="w-full h-[400px] rounded-2xl overflow-hidden shadow-lg">
        <iframe
          id="mapFrame"
          class="w-full h-full border-0"
          src="https://maps.google.com/maps?q=31.6295,-8.0089&z=13&output=embed">
        </iframe>
      </div>

    </div>

  </div>
</section>



<script>
  function focusMap(lat, lng) {
    const map = document.getElementById("mapFrame");
    map.src = `https://maps.google.com/maps?q=${lat},${lng}&z=14&output=embed`;
  }
</script>
