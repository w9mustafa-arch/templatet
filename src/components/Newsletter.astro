<section id="delivery-map" class="section py-16">
  <div class="container-custom mx-auto px-4">

    <div class="text-center max-w-3xl mx-auto mb-12">
      <span class="inline-block px-4 py-1 rounded-full bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 font-medium text-sm mb-4">
        Delivery Zones
      </span>

      <h2 class="text-3xl font-bold mb-6 text-gray-900 dark:text-white">
        Zones de livraison à Marrakech
      </h2>

      <p class="text-gray-600 dark:text-gray-300">
        Découvrez toutes les zones où nous livrons vos repas, courses et médicaments directement chez vous à Marrakech.
      </p>
    </div>

    <div class="max-w-5xl mx-auto">
      <div class="card p-2 border border-gray-200 dark:border-gray-700 rounded-2xl overflow-hidden shadow-lg bg-white dark:bg-gray-800">
        
        <div class="relative w-full rounded-xl overflow-hidden" style="height: 450px;">
          <iframe
            src="https://www.google.com/maps/d/u/2/embed?mid=1bLRE50rH78qFQ32T-_DmPU8QB5sw8h8&ehbc=2E312F" 
            style="
              position: absolute;
              top: -70px; /* رفع الخريطة لإخفاء الشريط الأسود */
              left: 0;
              width: 100%;
              height: calc(100% + 70px); /* تعويض الارتفاع المفقود من الأعلى */
              border: 0;
            "
            allowfullscreen=""
            loading="lazy"
          ></iframe>
        </div>
        
      </div>
    </div>

  </div>
</section>
