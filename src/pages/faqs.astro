---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
---

<Layout title="Frequently Asked Questions - Livraison Plus">
  <Header />
  <main>
    <HeroSection 
      title="Frequently Asked Questions" 
      highlightText="Questions"
      description="Find answers to common questions about our delivery services."
    />
    
    <section class="py-16 bg-white dark:bg-gray-800">
      <div class="container-custom">
        <div class="max-w-4xl mx-auto">

          <!-- Categories -->
          <div class="flex flex-wrap justify-center gap-4 mb-12">
            <a href="#general" class="px-4 py-2 rounded-full bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400 font-medium text-sm hover:bg-primary-200 dark:hover:bg-primary-800 transition-colors">General</a>
            <a href="#pricing" class="px-4 py-2 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium text-sm hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">Pricing</a>
            <a href="#features" class="px-4 py-2 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium text-sm hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">Features</a>
            <a href="#security" class="px-4 py-2 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium text-sm hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">Security</a>
            <a href="#support" class="px-4 py-2 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium text-sm hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">Support</a>
          </div>

          <!-- General -->
          <div id="general" class="mb-16">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">General Questions</h2>

            <div class="space-y-6">
              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">What is Livraison Plus?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  Livraison Plus is a fast and reliable delivery service that brings food, groceries, and everyday essentials directly to your doorstep.
                </p>
              </div>

              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">How does the delivery service work?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  Simply place your order, and our delivery team will pick it up and deliver it to your location as quickly as possible.
                </p>
              </div>

              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">What can I order?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  You can order meals, groceries, pharmacy items, and more—all in one place.
                </p>
              </div>

              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">Where is the service available?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  Our service is currently available in selected areas, and we are expanding to more locations soon.
                </p>
              </div>
            </div>
          </div>

          <!-- Pricing -->
          <div id="pricing" class="mb-16">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">Pricing</h2>

            <div class="space-y-6">
              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">How much does delivery cost?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  Delivery fees depend on distance and order type. The total price is always shown before confirming your order.
                </p>
              </div>

              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">Are there any hidden fees?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  No, all costs are transparent. You always see the final price before placing your order.
                </p>
              </div>

              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">What payment methods do you accept?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  We accept cash on delivery and online payment options depending on your location.
                </p>
              </div>
            </div>
          </div>

          <!-- Features -->
          <div id="features" class="mb-16">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">Features</h2>

            <div class="space-y-6">
              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">How fast is the delivery?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  Most orders are delivered within 30 to 60 minutes depending on your location.
                </p>
              </div>

              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">Can I track my order?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  Yes, you can track your order in real-time.
                </p>
              </div>

              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">Can I schedule a delivery?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  Yes, you can choose a preferred delivery time based on availability.
                </p>
              </div>
            </div>
          </div>

          <!-- Security -->
          <div id="security" class="mb-16">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">Security & Privacy</h2>

            <div class="space-y-6">
              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">Is my personal information safe?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  Yes, we protect your personal data and ensure it is never shared without your consent.
                </p>
              </div>

              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">Are payments secure?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  All payments are processed securely using trusted methods.
                </p>
              </div>
            </div>
          </div>

          <!-- Support -->
          <div id="support" class="mb-16">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">Support</h2>

            <div class="space-y-6">
              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">How can I contact support?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  You can contact us via phone, WhatsApp, or through our contact page.
                </p>
              </div>

              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">What if my order is late or incorrect?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  If there is any issue with your order, contact us immediately and we will resolve it as quickly as possible.
                </p>
              </div>
            </div>
          </div>

          <!-- CTA -->
          <div class="text-center mt-16">
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Still have questions?</h3>
            <p class="text-gray-600 dark:text-gray-300 mb-8">
              Our team is here to help you anytime.
            </p>
            <a href="/contact" class="btn-primary">Contact Us</a>
          </div>

        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
