---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
---

<Layout title="Frequently Asked Questions - Simo Delivery">
  <Header />
  <main>
    <HeroSection 
      title="Frequently Asked Questions" 
      highlightText="Questions"
      description="Find answers to common questions about our delivery service."
    />
    
    <section class="py-16 bg-white dark:bg-gray-800">
      <div class="container-custom">
        <div class="max-w-4xl mx-auto">

          <!-- Categories -->
          <div class="flex flex-wrap justify-center gap-4 mb-12">
            <a href="#general" class="px-4 py-2 rounded-full bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400 font-medium text-sm hover:bg-primary-200 dark:hover:bg-primary-800 transition-colors">General</a>
            <a href="#features" class="px-4 py-2 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium text-sm hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">Service</a>
            <a href="#security" class="px-4 py-2 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium text-sm hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">Privacy</a>
            <a href="#support" class="px-4 py-2 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium text-sm hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">Support</a>
          </div>

          <!-- General -->
          <div id="general" class="mb-16">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">General Questions</h2>

            <div class="space-y-6">
              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">What is Simo Delivery?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  Simo Delivery is a fast and reliable delivery service that helps you receive food, groceries, and other items directly at your location.
                </p>
              </div>

              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">Where is the service available?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  Our service is available across Marrakech and surrounding areas.
                </p>
              </div>
            </div>
          </div>

          <!-- Service -->
          <div id="features" class="mb-16">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">How the Service Works</h2>

            <div class="space-y-6">
              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">How do I place an order?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  You can place your order by contacting us via WhatsApp or phone and sending your request along with your delivery location.
                </p>
              </div>

              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">How long does delivery take?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  Delivery usually takes between 30 to 45 minutes depending on the distance.
                </p>
              </div>

              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">Can I track my order?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  Currently, order tracking is not available. However, we always aim to deliver your order as quickly as possible.
                </p>
              </div>
            </div>
          </div>

          <!-- Privacy -->
          <div id="security" class="mb-16">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">Privacy</h2>

            <div class="space-y-6">
              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">Is my personal information safe?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  Yes, we respect your privacy and ensure your personal information is kept secure and confidential.
                </p>
              </div>
            </div>
          </div>

          <!-- Support -->
          <div id="support" class="mb-16">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">Support</h2>

            <div class="space-y-6">
              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">How can I contact you?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  You can contact us anytime via WhatsApp or phone, and we will respond as quickly as possible.
                </p>
              </div>

              <div class="card p-6 border border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold mb-3">What if there is an issue with my order?</h3>
                <p class="text-gray-600 dark:text-gray-300">
                  If you have any issue with your order, please contact us immediately and we will do our best to resolve it quickly.
                </p>
              </div>
            </div>
          </div>

          <!-- CTA -->
          <div class="text-center mt-16">
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Still have questions?</h3>
            <p class="text-gray-600 dark:text-gray-300 mb-8">
              Contact us and we will be happy to help you.
            </p>
            <a href="/contact" class="btn-primary">Contact Us</a>
          </div>

        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
